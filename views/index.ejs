<h1>Welcome to CSE Motors!</h1>
<section class="hero">
    <img src="/images/vehicles/delorean.jpg" alt="car">
    <div class="hero-text">
        <h3>DMC Delorean</h3>
        <div class="list">
            <ul>
                <li>3 Cup holders</li>
                <li>Superman doors</li>
                <li>Fuzzy dice!</li>
            </ul>
        </div>
        <input type="button" class="button-blue" value="Own Today">
    </div>
</section>

<div class="content">
    <section id="upgrades">
        <h2>Delorean Upgrades</h2>
        <div class="gallery">
            <div class="caption-image">
                <div>
                    <img src="/images/upgrades/flux-cap.png" alt="Flux capacitor">
                </div>
                <p><a href="#">Flux Capacitor</a></p>
            </div>
            <div class="caption-image">
                <div>
                    <img src="/images/upgrades/flame.jpg" alt="Flame decal">
                </div>
                <p><a href="#">Flame Decals</a></p>
            </div>
            <div class="caption-image">
                <div>
                    <img src="/images/upgrades/bumper_sticker.jpg" alt="Hello world bumper sticker">
                </div>
                <p><a href="#">Bumper Stickers</a></p>
            </div>
            <div class="caption-image">
                <div>
                    <img src="/images/upgrades/hub-cap.jpg" alt="Hub cap">
                </div>
                <p><a href="#">Hub Caps</a></p>
            </div>
        </div>
    </section>
    
    <section id="reviews">
        <h2>DMC Delorean Reviews</h2>
        <ul class="open">
            <li>
                <p>"So fast it's almost like traveling in time."</p>
                <p>(4/5)</p> 
            </li>
            <li>
                <p>"Coolest ride on the road."</p>
                <p>(4/5)</p>
            </li>
            <li>
                <p>"I'm feeling McFly!"</p>
                <p>(5/5)</p>
            </li>
            <li>
                <p>"The most futuristic ride of our day."</p>
                <p>(4.5/5)</p>
            </li>
            <li>
                <p>"80's livin and I love it."</p>
                <p>(5/5)</p>
            </li>
        </ul>
    </section>
</div>

